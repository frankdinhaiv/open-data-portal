# Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=arena
MYSQL_PASSWORD=
MYSQL_DATABASE=arena

# Redis
REDIS_URL=redis://localhost:6379/0

# HaiMaker
HAIMAKER_API_URL=https://app.haimaker.ai/api
HAIMAKER_API_KEY=

# Direct API fallbacks
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Auth
JWT_SECRET=  # REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=30

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Google OAuth (handled by auth team)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Feature flags
EVENT_MODE=false
ENABLE_STREAMING=true
ELO_MODE=batch

# Rate limits
RATE_LIMIT_VOTES_PER_HOUR=100
RATE_LIMIT_VOTES_PER_HOUR_EVENT=200
